---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import ScrollBlurImage from "../components/ScrollBlurImage.astro";
import ContactCta from "../components/ContactCta.astro";
import AutoImageSlider from "../components/AutoImageSlider.astro";

const services = [
  {
    number: "01",
    title: "Correction de vernis",
    text: "Polissage et poli-lustrage pour corriger les micro-rayures, hologrammes et défauts de surface.",
    link: "/prestations",
  },
  {
    number: "02",
    title: "Protection carrosserie",
    text: "Cire de prestige à la carnauba ou traitement céramique longue durée pour préserver l’éclat.",
    link: "/prestations",
  },
  {
    number: "03",
    title: "Rénovation d’optiques",
    text: "Polissage et vernissage des phares pour retrouver transparence, esthétique et sécurité.",
    link: "/prestations",
  },
  {
    number: "04",
    title: "Films teintés",
    text: "Pose de films haute performance pour le confort, le style, la protection solaire et la confidentialité.",
    link: "/prestations",
  },
];

const ppfImages = [
  {
    src: "/images/ppf-1.webp",
    alt: "Pose de film PPF sur optique - préparation",
  },
  {
    src: "/images/ppf-2.webp",
    alt: "Pose de film PPF sur optique - application du film",
  },
  {
    src: "/images/ppf-3.webp",
    alt: "Pose de film PPF sur optique - ajustement et finition",
  },
];

const values = ["Artisanat", "Passion", "Détail", "Excellence", "Authenticité"];
---

<BaseLayout
  title="L’art de l’éclat – Detailing automobile à Trévé près de Loudéac"
  description="L’art de l’éclat restaure, protège et sublime votre véhicule : correction de vernis, protection céramique, rénovation de phares et films teintés."
>
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden">
      <div
        class="absolute right-0 top-0 h-80 w-80 rounded-full bg-[var(--gold)]/20 blur-3xl float-slow"
      >
      </div>
      <div
        class="absolute left-0 top-64 h-64 w-64 rounded-full bg-[var(--gold-light)]/10 blur-3xl float-delay"
      >
      </div>

      <div
        class="mx-auto grid min-h-[50vh] max-w-7xl items-center gap-10 px-4 py-10 sm:px-6 md:py-14 lg:grid-cols-[1fr_0.95fr]"
      >
        <div class="slide-right">
          <div class="french-line mb-6"></div>

          <div class="gold-chip">
            <span class="gold-dot"></span>
            Expert detailing automobile
          </div>

          <h1
            class="mt-6 text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl"
          >
            Restaurer,<br />
            protéger,<br />
            <span class="gold-text">sublimer.</span>
          </h1>

          <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/72">
            L’art de l’éclat est un atelier spécialisé dans l’esthétique
            automobile de précision à Trévé, près de Loudéac.
          </p>

          <p class="mt-4 max-w-xl text-base leading-relaxed text-white/55">
            Correction de vernis, protection carrosserie, rénovation d’optiques
            et pose de films teintés.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact"
              class="rounded-full bg-[var(--gold)] px-7 py-3.5 font-semibold text-black shadow-lg shadow-yellow-900/30 hover:bg-[var(--gold-light)]"
            >
              Demander un devis
            </a>

            <a
              href="/prestations"
              class="rounded-full border border-white/20 px-7 py-3.5 font-semibold text-white hover:border-[var(--gold)] hover:text-[var(--gold-light)]"
            >
              Voir les prestations
            </a>
          </div>
        </div>

        <div class="relative slide-left">
          <div
            class="absolute -inset-5 rounded-[2.5rem] bg-[var(--gold)]/20 blur-3xl"
          >
          </div>

          <div class="relative home-glow-card rounded-[2.5rem]">
            <img
              src="/images/logo-art-eclat-hero.webp"
              alt="L’art de l’éclat"
              class="mx-auto w-full object-contain"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- PRESTATION À VENIR : FORFAIT BLINDAGE -->
    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
      <div class="home-glow-card zoom-in overflow-hidden rounded-[2.5rem]">
        <div class="grid gap-0 lg:grid-cols-[0.9fr_1.1fr] lg:items-stretch">
          <!-- TEXTE -->
          <div class="flex flex-col justify-center p-8 md:p-12">
            <div
              class="mb-5 inline-flex w-fit rounded-full border border-[var(--gold)]/40 bg-[var(--gold)]/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.25em] text-[var(--gold-light)]"
            >
              Bientôt disponible
            </div>

            <p class="text-sm uppercase tracking-[0.35em] text-white/45">
              Nouvelle prestation
            </p>

            <h2 class="mt-4 text-4xl font-semibold leading-tight md:text-5xl">
              Forfait <span class="gold-text">Blindage</span><br />
              pour optiques.
            </h2>

            <p class="mt-6 text-lg leading-relaxed text-white/70">
              Une rénovation ultime des phares, pensée pour remplacer le
              vernissage par la pose d’un film de protection transparent appelé <strong
                class="text-[var(--gold-light)]">PPF</strong
              >.
            </p>

            <div class="mt-8 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
                <p
                  class="text-sm uppercase tracking-[0.2em] text-[var(--gold-light)]"
                >
                  Durabilité
                </p>
                <p class="mt-2 text-white/75">Garantie jusqu’à 10 ans</p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
                <p
                  class="text-sm uppercase tracking-[0.2em] text-[var(--gold-light)]"
                >
                  Contrôle
                </p>
                <p class="mt-2 text-white/75">Visite annuelle offerte</p>
              </div>
            </div>

            <div class="mt-8 flex flex-wrap items-center gap-4">
              <div
                class="rounded-full bg-[var(--gold)] px-6 py-3 font-bold text-black"
              >
                120 €
              </div>

              <p class="text-sm text-white/50">
                Prestation bientôt en phase de test.
              </p>
            </div>

            <a
              href="/contact"
              class="mt-8 inline-flex w-fit rounded-full border border-[var(--gold)] px-7 py-3 font-semibold text-[var(--gold-light)] hover:bg-[var(--gold)] hover:text-black"
            >
              Me prévenir / demander des infos
            </a>
          </div>

          <!-- VISUEL -->
          <div
            class="relative min-h-[360px] overflow-hidden border-t border-white/10 bg-black/50 lg:border-l lg:border-t-0"
          >
            <AutoImageSlider
              images={ppfImages}
              intervalMs={3000}
              minHeight="360px"
              objectFit="cover"
              overlay={true}
              className="h-full"
            />

            <div
              class="absolute bottom-6 left-6 right-6 z-10 rounded-[1.5rem] border border-[var(--gold)]/35 bg-black/70 p-5 backdrop-blur"
            >
              <p
                class="text-sm uppercase tracking-[0.25em] text-[var(--gold-light)]"
              >
                PPF transparent
              </p>

              <p class="mt-2 text-lg font-semibold text-white">
                Une protection physique contre les agressions extérieures.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOCS RAPIDES -->
    <section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 md:py-14">
      <div class="grid gap-4 md:grid-cols-3">
        <article class="home-glow-card fade-in rounded-[2rem] p-6">
          <p class="service-number">PRÉCISION</p>
          <h2 class="mt-3 text-2xl font-semibold text-[var(--gold-light)]">
            Un travail au détail
          </h2>
          <p class="mt-4 leading-relaxed text-white/65">
            Chaque véhicule est observé, préparé et traité selon son état réel.
          </p>
        </article>

        <article class="home-glow-card fade-in rounded-[2rem] p-6">
          <p class="service-number">PROTECTION</p>
          <h2 class="mt-3 text-2xl font-semibold text-[var(--gold-light)]">
            Des solutions durables
          </h2>
          <p class="mt-4 leading-relaxed text-white/65">
            Cire carnauba, céramique, vernis optiques ou films haute
            performance.
          </p>
        </article>

        <article class="home-glow-card fade-in rounded-[2rem] p-6">
          <p class="service-number">ÉCLAT</p>
          <h2 class="mt-3 text-2xl font-semibold text-[var(--gold-light)]">
            Un rendu premium
          </h2>
          <p class="mt-4 leading-relaxed text-white/65">
            L’objectif : redonner au véhicule son aspect d’origine, voire mieux
            que le neuf.
          </p>
        </article>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
      <div class="mb-10 max-w-3xl fade-in">
        <p class="text-sm uppercase tracking-[0.35em] text-[var(--gold-light)]">
          Prestations
        </p>

        <h2 class="mt-4 text-4xl font-semibold md:text-5xl">
          L’essentiel pour révéler l’éclat du véhicule.
        </h2>

        <p class="mt-5 text-lg leading-relaxed text-white/65">
          Des prestations claires, ciblées et adaptées à l’état du support.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          services.map((service, index) => (
            <a
              href={service.link}
              class={`home-glow-card rounded-[2rem] p-6 transition hover:-translate-y-1 ${
                index % 2 === 0 ? "slide-right" : "slide-left"
              }`}
            >
              <p class="service-number">{service.number}</p>

              <h3 class="mt-4 text-2xl font-semibold text-[var(--gold-light)]">
                {service.title}
              </h3>

              <p class="mt-4 leading-relaxed text-white/65">{service.text}</p>

              <p class="mt-6 text-sm font-semibold text-[var(--gold-light)]">
                En savoir plus →
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- IMAGE + TEXTE -->
    <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-16">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch">
        <div class="relative home-glow-card rounded-[2.5rem]">
          <ScrollBlurImage
            src="/images/logo-art-eclat-hero.webp"
            alt="Logo L’art de l’éclat"
            className="min-h-[360px]"
            imageClass="min-h-[360px]"
          />
        </div>

        <div
          class="home-glow-card slide-left flex flex-col justify-center rounded-[2.5rem] p-8 md:p-10"
        >
          <p
            class="text-sm uppercase tracking-[0.35em] text-[var(--gold-light)]"
          >
            Savoir-faire
          </p>

          <h2 class="mt-4 text-4xl font-semibold">
            Une esthétique automobile de précision.
          </h2>

          <p class="mt-6 text-lg leading-relaxed text-white/70">
            L’art de l’éclat restaure, protège et sublime chaque véhicule grâce
            à un savoir-faire artisanal et à des produits de haute technicité.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {
              values.map((value) => (
                <span class="rounded-full border border-[var(--gold)]/30 bg-[var(--gold)]/10 px-4 py-2 text-sm text-[var(--gold-light)]">
                  {value}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- APERÇU RÉALISATIONS -->
    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
      <div class="mb-10 max-w-3xl fade-in">
        <p class="text-sm uppercase tracking-[0.35em] text-[var(--gold-light)]">
          Réalisations
        </p>

        <h2 class="mt-4 text-4xl font-semibold md:text-5xl">
          Des résultats visibles dès le premier regard.
        </h2>

        <p class="mt-5 text-lg leading-relaxed text-white/65">
          Correction de vernis, rénovation d’optiques et finitions premium :
          chaque intervention vise un résultat net, durable et soigné.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <a
          href="/realisations"
          class="home-glow-card slide-right group overflow-hidden rounded-[2rem]"
        >
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src="/images/vernis.webp"
              alt="Correction de vernis automobile"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
          </div>

          <div class="p-6">
            <p class="service-number">VERNIS</p>
            <h3 class="mt-3 text-2xl font-semibold text-[var(--gold-light)]">
              Brillance retrouvée
            </h3>
            <p class="mt-4 text-white/65">
              Travail de correction pour retrouver profondeur, éclat et
              finition.
            </p>
          </div>
        </a>

        <a
          href="/realisations"
          class="home-glow-card slide-left group overflow-hidden rounded-[2rem]"
        >
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src="/images/optique-1-apres.webp"
              alt="Rénovation d’optique automobile"
              class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
            />
          </div>

          <div class="p-6">
            <p class="service-number">OPTIQUES</p>
            <h3 class="mt-3 text-2xl font-semibold text-[var(--gold-light)]">
              Phares rénovés
            </h3>
            <p class="mt-4 text-white/65">
              Transparence, sécurité et esthétique grâce à une rénovation
              soignée.
            </p>
          </div>
        </a>
      </div>
    </section>
    <!-- FORMATION / DIPLÔMES -->
    <section class="mx-auto max-w-7xl px-4 py-14 sm:px-6 md:py-20">
      <div class="home-glow-card zoom-in overflow-hidden rounded-[2.5rem]">
        <div class="grid gap-0 lg:grid-cols-[0.75fr_1.25fr] lg:items-stretch">
          <div
            class="relative z-10 flex flex-col justify-center border-b border-white/10 bg-black/80 p-8 md:p-12 lg:border-b-0 lg:border-r"
          >
            <p
              class="text-sm uppercase tracking-[0.35em] text-[var(--gold-light)]"
            >
              Formation & savoir-faire
            </p>

            <h2 class="mt-4 text-4xl font-semibold md:text-5xl">
              Des compétences techniques au service du résultat.
            </h2>

            <p class="mt-6 text-lg leading-relaxed text-white/70">
              Jérémy Martin a suivi une formation professionnelle en detailing
              automobile. Cette base technique permet d’intervenir avec méthode
              sur la préparation, la rénovation, la correction et la finition
              des véhicules.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              <span
                class="rounded-full border border-[var(--gold)]/30 bg-[var(--gold)]/10 px-4 py-2 text-sm text-[var(--gold-light)]"
              >
                Detailing automobile
              </span>

              <span
                class="rounded-full border border-[var(--gold)]/30 bg-[var(--gold)]/10 px-4 py-2 text-sm text-[var(--gold-light)]"
              >
                Pose de films teintés
              </span>

              <span
                class="rounded-full border border-[var(--gold)]/30 bg-[var(--gold)]/10 px-4 py-2 text-sm text-[var(--gold-light)]"
              >
                Finition premium
              </span>
            </div>

            <a
              href="/a-propos"
              class="mt-8 inline-flex w-fit rounded-full border border-[var(--gold)] px-7 py-3 font-semibold text-[var(--gold-light)] hover:bg-[var(--gold)] hover:text-black"
            >
              Découvrir le savoir-faire
            </a>
          </div>

          <a
            href="/a-propos"
            class="group flex min-h-[360px] items-center justify-center bg-black/40 p-4 md:min-h-[460px] md:p-6"
          >
            <img
              src="/images/diplome-formation-detailing.webp"
              alt="Formation detailing automobile - Jérémy Martin"
              class="h-auto max-h-[520px] w-full object-contain transition duration-700 group-hover:scale-[1.02]"
            />
          </a>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <ContactCta />
  </main>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const slides = document.querySelectorAll(".ppf-slide");
      if (!slides.length) return;

      let current = 0;

      setInterval(() => {
        slides[current].classList.remove("is-active");
        current = (current + 1) % slides.length;
        slides[current].classList.add("is-active");
      }, 3200);
    });
  </script>

  <ScrollReveal />
</BaseLayout>
