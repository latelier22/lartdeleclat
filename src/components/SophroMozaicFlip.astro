---
const {
  images = [],
  intervalMs = 2400,
} = Astro.props;

const id = `mosaic-flip-${Math.random().toString(36).slice(2, 9)}`;

const tiles = [
  { col: 1, row: 1, colSpan: 2, rowSpan: 2 },
  { col: 3, row: 1, colSpan: 2, rowSpan: 3 },
  { col: 5, row: 1, colSpan: 2, rowSpan: 2 },
  { col: 1, row: 3, colSpan: 2, rowSpan: 1 },
  { col: 5, row: 3, colSpan: 2, rowSpan: 1 },
  { col: 1, row: 4, colSpan: 3, rowSpan: 3 },
  { col: 4, row: 4, colSpan: 1, rowSpan: 2 },
  { col: 5, row: 4, colSpan: 2, rowSpan: 3 },
  { col: 4, row: 6, colSpan: 1, rowSpan: 1 },
];

const safeImages = Array.isArray(images) ? images.filter(Boolean) : [];
---

{safeImages.length > 0 && (
  <section id={id} class="mosaic-flip" data-interval={intervalMs}>
    <div class="mosaic-flip__grid">
      {tiles.map((tile, index) => (
        <article
          class="mosaic-flip__tile"
          style={`grid-column:${tile.col} / span ${tile.colSpan}; grid-row:${tile.row} / span ${tile.rowSpan};`}
          data-tile={index}
        >
          <div class="mosaic-flip__inner">
            <button
              type="button"
              class="mosaic-flip__face mosaic-flip__face--front"
              data-open-modal
              data-image-index={index % safeImages.length}
              aria-label={`Ouvrir l’image ${index + 1}`}
            >
              <img
                src={safeImages[index % safeImages.length]}
                alt={`Réalisation ${index + 1}`}
                class="mosaic-flip__img"
                data-front
                loading="eager"
              />
            </button>

            <button
              type="button"
              class="mosaic-flip__face mosaic-flip__face--back"
              data-open-modal
              data-image-index={(index + tiles.length) % safeImages.length}
              aria-label={`Ouvrir l’image ${index + 1}`}
            >
              <img
                src={safeImages[(index + tiles.length) % safeImages.length]}
                alt={`Réalisation ${index + 1}`}
                class="mosaic-flip__img"
                data-back
                loading="lazy"
              />
            </button>
          </div>
        </article>
      ))}
    </div>

    <div class="mosaic-lightbox" data-lightbox hidden>
      <div class="mosaic-lightbox__backdrop" data-close-lightbox></div>

      <div
        class="mosaic-lightbox__panel"
        role="dialog"
        aria-modal="true"
        aria-label="Galerie des réalisations"
      >
        <button
          type="button"
          class="mosaic-lightbox__close"
          data-close-lightbox
          aria-label="Fermer"
        >
          ×
        </button>

        <button
          type="button"
          class="mosaic-lightbox__arrow mosaic-lightbox__arrow--prev"
          data-lightbox-prev
          aria-label="Image précédente"
        >
          ‹
        </button>

        <div class="mosaic-lightbox__content">
          <img
            src=""
            alt="Réalisation agrandie"
            class="mosaic-lightbox__img"
            data-lightbox-image
          />
        </div>

        <button
          type="button"
          class="mosaic-lightbox__arrow mosaic-lightbox__arrow--next"
          data-lightbox-next
          aria-label="Image suivante"
        >
          ›
        </button>
      </div>
    </div>
  </section>
)}

<script is:inline define:vars={{ id, safeImages }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const tiles = Array.from(root.querySelectorAll("[data-tile]"));
    const intervalMs = Number(root.dataset.interval || 2400);
    const pool = safeImages.slice();

    if (!tiles.length || !pool.length) return;

    let globalIndex = tiles.length * 2;
    let currentTile = 0;

    const nextImage = () => {
      const src = pool[globalIndex % pool.length];
      const index = globalIndex % pool.length;
      globalIndex += 1;
      return { src, index };
    };

    const flipTile = (tile) => {
      if (!tile) return;

      const inner = tile.querySelector(".mosaic-flip__inner");
      const front = tile.querySelector("[data-front]");
      const back = tile.querySelector("[data-back]");

      if (!inner || !front || !back) return;

      const isFlipped = inner.classList.contains("is-flipped");
      const next = nextImage();

      if (!isFlipped) {
        back.src = next.src;

        const backButton = back.closest("[data-open-modal]");
        if (backButton) {
          backButton.setAttribute("data-image-index", String(next.index));
        }

        inner.classList.add("is-flipped");
      } else {
        front.src = next.src;

        const frontButton = front.closest("[data-open-modal]");
        if (frontButton) {
          frontButton.setAttribute("data-image-index", String(next.index));
        }

        inner.classList.remove("is-flipped");
      }
    };

    const tick = () => {
      const tile = tiles[currentTile % tiles.length];
      flipTile(tile);
      currentTile += 1;
    };

    let timer = window.setInterval(tick, intervalMs);

    root.addEventListener("mouseenter", () => {
      if (timer) {
        clearInterval(timer);
      }
    });

    root.addEventListener("mouseleave", () => {
      if (timer) {
        clearInterval(timer);
      }

      timer = window.setInterval(tick, intervalMs);
    });

    const lightbox = root.querySelector("[data-lightbox]");
    const lightboxImg = root.querySelector("[data-lightbox-image]");
    const closeButtons = root.querySelectorAll("[data-close-lightbox]");
    const prevBtn = root.querySelector("[data-lightbox-prev]");
    const nextBtn = root.querySelector("[data-lightbox-next]");
    const openButtons = root.querySelectorAll("[data-open-modal]");

    let modalIndex = 0;

    const setModalImage = () => {
      if (!lightboxImg || !pool.length) return;

      modalIndex = (modalIndex + pool.length) % pool.length;
      lightboxImg.src = pool[modalIndex];
    };

    const openModal = (index) => {
      if (!lightbox) return;

      modalIndex = index;
      setModalImage();

      lightbox.hidden = false;

      requestAnimationFrame(() => {
        lightbox.classList.add("is-open");
      });
    };

    const closeModal = () => {
      if (!lightbox) return;

      lightbox.classList.remove("is-open");

      setTimeout(() => {
        lightbox.hidden = true;
      }, 240);
    };

    const nextModal = () => {
      modalIndex += 1;
      setModalImage();
    };

    const prevModal = () => {
      modalIndex -= 1;
      setModalImage();
    };

    openButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const index = Number(btn.getAttribute("data-image-index") || "0");
        openModal(index);
      });
    });

    closeButtons.forEach((btn) => {
      btn.addEventListener("click", closeModal);
    });

    prevBtn?.addEventListener("click", prevModal);
    nextBtn?.addEventListener("click", nextModal);

    document.addEventListener("keydown", (event) => {
      if (!lightbox || lightbox.hidden) return;

      if (event.key === "Escape") {
        closeModal();
      }

      if (event.key === "ArrowRight") {
        nextModal();
      }

      if (event.key === "ArrowLeft") {
        prevModal();
      }
    });
  })();
</script>

<style>
  .mosaic-flip {
    width: 100%;
  }

  .mosaic-flip__grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    grid-template-rows: repeat(6, 92px);
    gap: 14px;
  }

  .mosaic-flip__tile {
    min-height: 0;
    perspective: 1100px;
  }

  .mosaic-flip__inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 900ms ease;
  }

  .mosaic-flip__inner.is-flipped {
    transform: rotateY(180deg);
  }

  .mosaic-flip__face {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid rgba(214, 162, 63, 0.38);
    border-radius: 1.35rem;
    background: #050505;
    backface-visibility: hidden;
    box-shadow:
      0 18px 55px rgba(0, 0, 0, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.035);
  }

  .mosaic-flip__face--back {
    transform: rotateY(180deg);
  }

  .mosaic-flip__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition:
      transform 700ms ease,
      filter 700ms ease;
  }

  .mosaic-flip__face:hover .mosaic-flip__img {
    transform: scale(1.06);
    filter: brightness(1.08);
  }

  .mosaic-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 240ms ease;
  }

  .mosaic-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .mosaic-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.84);
    backdrop-filter: blur(8px);
  }

  .mosaic-lightbox__panel {
    position: relative;
    z-index: 2;
    width: min(92vw, 1100px);
    height: min(84vh, 760px);
    display: grid;
    place-items: center;
  }

  .mosaic-lightbox__content {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border: 1px solid rgba(214, 162, 63, 0.46);
    border-radius: 2rem;
    background: #050505;
    box-shadow: 0 30px 90px rgba(0, 0, 0, 0.85);
  }

  .mosaic-lightbox__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .mosaic-lightbox__close,
  .mosaic-lightbox__arrow {
    position: absolute;
    z-index: 4;
    border: 1px solid rgba(214, 162, 63, 0.5);
    background: rgba(0, 0, 0, 0.74);
    color: #f4d27a;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition:
      background 200ms ease,
      color 200ms ease,
      transform 200ms ease;
  }

  .mosaic-lightbox__close:hover,
  .mosaic-lightbox__arrow:hover {
    background: #d6a23f;
    color: #050505;
  }

  .mosaic-lightbox__close {
    top: -18px;
    right: -18px;
    width: 46px;
    height: 46px;
    border-radius: 999px;
    font-size: 30px;
    line-height: 1;
  }

  .mosaic-lightbox__arrow {
    top: 50%;
    width: 54px;
    height: 54px;
    border-radius: 999px;
    transform: translateY(-50%);
    font-size: 42px;
    line-height: 1;
  }

  .mosaic-lightbox__arrow:hover {
    transform: translateY(-50%) scale(1.04);
  }

  .mosaic-lightbox__arrow--prev {
    left: -26px;
  }

  .mosaic-lightbox__arrow--next {
    right: -26px;
  }

  @media (max-width: 900px) {
    .mosaic-flip__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      grid-template-rows: repeat(7, 90px);
    }

    .mosaic-flip__tile:nth-child(1) {
      grid-column: 1 / span 2 !important;
      grid-row: 1 / span 2 !important;
    }

    .mosaic-flip__tile:nth-child(2) {
      grid-column: 3 / span 2 !important;
      grid-row: 1 / span 2 !important;
    }

    .mosaic-flip__tile:nth-child(3) {
      grid-column: 1 / span 2 !important;
      grid-row: 3 / span 2 !important;
    }

    .mosaic-flip__tile:nth-child(4) {
      grid-column: 3 / span 2 !important;
      grid-row: 3 / span 2 !important;
    }

    .mosaic-flip__tile:nth-child(5) {
      grid-column: 1 / span 4 !important;
      grid-row: 5 / span 2 !important;
    }

    .mosaic-flip__tile:nth-child(n + 6) {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .mosaic-flip__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
      gap: 12px;
    }

    .mosaic-flip__tile {
      grid-column: auto !important;
      grid-row: auto !important;
      aspect-ratio: 1 / 1;
    }

    .mosaic-flip__tile:nth-child(n + 7) {
      display: none;
    }

    .mosaic-lightbox__panel {
      width: 94vw;
      height: 76vh;
    }

    .mosaic-lightbox__content {
      border-radius: 1.4rem;
    }

    .mosaic-lightbox__arrow--prev {
      left: 8px;
    }

    .mosaic-lightbox__arrow--next {
      right: 8px;
    }

    .mosaic-lightbox__close {
      top: 8px;
      right: 8px;
    }
  }
</style>