---
const { title, text } = Astro.props;
---

<article class="premium-card rounded-[1.5rem] p-6 transition hover:-translate-y-1 hover:border-[var(--gold)]">
  <div class="mb-5 h-10 w-10 rounded-full border border-[var(--gold)] bg-[var(--gold)]/10"></div>

  <h3 class="text-xl font-semibold text-[var(--gold-light)]">
    {title}
  </h3>

  <p class="mt-4 leading-relaxed text-white/70">
    {text}
  </p>
</article>