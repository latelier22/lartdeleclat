---
const {
  images = [],
  intervalMs = 3200,
  minHeight = "360px",
  rounded = "0",
  objectFit = "cover",
  overlay = true,
  className = "",
} = Astro.props;

const id = `auto-slider-${Math.random().toString(36).slice(2, 9)}`;
const safeImages = Array.isArray(images) ? images.filter(Boolean) : [];
---

{safeImages.length > 0 && (
  <div
    id={id}
    class={`auto-image-slider ${className}`}
    data-interval={intervalMs}
    style={`min-height:${minHeight}; border-radius:${rounded};`}
  >
    {safeImages.map((image, index) => (
      <img
        src={typeof image === "string" ? image : image.src}
        alt={typeof image === "string" ? `Image ${index + 1}` : image.alt}
        class={`auto-image-slider__slide ${index === 0 ? "is-active" : ""}`}
        style={`object-fit:${objectFit};`}
        loading={index === 0 ? "eager" : "lazy"}
      />
    ))}

    {overlay && <div class="auto-image-slider__overlay"></div>}

    <div class="auto-image-slider__dots">
      {safeImages.map((_, index) => (
        <button
          type="button"
          class={`auto-image-slider__dot ${index === 0 ? "is-active" : ""}`}
          data-slider-dot={index}
          aria-label={`Afficher l’image ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
)}

<script is:inline define:vars={{ id }}>
  (() => {
    const root = document.getElementById(id);
    if (!root) return;

    const slides = Array.from(root.querySelectorAll(".auto-image-slider__slide"));
    const dots = Array.from(root.querySelectorAll("[data-slider-dot]"));
    const intervalMs = Number(root.dataset.interval || 3200);

    if (!slides.length) return;

    let current = 0;
    let timer = null;

    const showSlide = (index) => {
      slides[current]?.classList.remove("is-active");
      dots[current]?.classList.remove("is-active");

      current = (index + slides.length) % slides.length;

      slides[current]?.classList.add("is-active");
      dots[current]?.classList.add("is-active");
    };

    const start = () => {
      if (timer) clearInterval(timer);

      timer = setInterval(() => {
        showSlide(current + 1);
      }, intervalMs);
    };

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const index = Number(dot.getAttribute("data-slider-dot") || "0");
        showSlide(index);
        start();
      });
    });

    root.addEventListener("mouseenter", () => {
      if (timer) clearInterval(timer);
    });

    root.addEventListener("mouseleave", start);

    start();
  })();
</script>

<style>
  .auto-image-slider {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #050505;
  }

  .auto-image-slider__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: inherit;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 900ms ease,
      transform 2400ms ease;
  }

  .auto-image-slider__slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .auto-image-slider__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
      linear-gradient(
        90deg,
        rgba(0,0,0,0.55),
        rgba(0,0,0,0.12),
        rgba(0,0,0,0.30)
      );
  }

  .auto-image-slider__dots {
    position: absolute;
    z-index: 4;
    left: 50%;
    bottom: 16px;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }

  .auto-image-slider__dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 1px solid rgba(244, 210, 122, 0.7);
    background: rgba(0, 0, 0, 0.55);
    cursor: pointer;
    padding: 0;
    transition:
      width 200ms ease,
      background 200ms ease;
  }

  .auto-image-slider__dot.is-active {
    width: 26px;
    background: #f4d27a;
  }
</style>